{
  "name": "portfolio_website",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i src/input.css -o site/styles.css --minify",
    "build:site": "bun build.js",
    "build": "bun run build:site && bun run build:css",
    "watch:css": "tailwindcss -i src/input.css -o site/styles.css --watch",
    "watch": "bun run build && bun --watch build.js"
  },
  "devDependencies": {
    "@tailwindcss/forms": "0.5",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "3"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.5"
  }
}
